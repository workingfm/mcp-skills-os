# Copia questo file in .env e modifica i valori
# cp .env.example .env

# Sandbox: "mock" (default, no Docker-in-Docker) | "docker" (produzione)
SKILL_OS_SANDBOX=mock

# Orchestratore autonomo: "false" (default) | "true"
ORCHESTRATOR_ENABLED=false
ORCHESTRATOR_INTERVAL=1800

# Auto-approvazione proposte sicure: "false" (default) | "true"
# Quando attivo, le skill senza side_effects vengono approvate automaticamente.
# Le skill con side_effects richiedono sempre approvazione manuale.
AUTO_APPROVE_SAFE=false
AUTO_APPROVE_MIN_SCORE=7.0

# NON serve ANTHROPIC_API_KEY.
# Il ragionamento LLM passa attraverso MCP sampling → abbonamento Claude Pro.

# Timeout approvazione upsert in secondi
APPROVAL_TIMEOUT_SECONDS=300

# ASR — Adaptive Skill Reinforcement
ASR_ENABLED=true                  # Attiva/disattiva evoluzione adattiva
ASR_MAX_RETRIES=1                 # Max retry per episodio
ASR_MAX_MUTATIONS_PER_DAY=5       # Max mutazioni giornaliere per skill
ASR_STABILITY_THRESHOLD=10        # Successi consecutivi per status "stable"
ASR_DEGRADED_AFTER_ROLLBACKS=3    # Rollback consecutivi per status "degraded"
ASR_FITNESS_ALPHA=0.3             # Peso nuovo episodio nel calcolo fitness
ASR_MAX_EPISODES=200              # Max episodi nel fitness store
ASR_MAX_SNAPSHOTS=20              # Max snapshot per skill
ASR_COOLDOWN_SECONDS=300          # Cooldown tra mutazioni sulla stessa skill (5 min)
